# copy .env.example .env 후 OPENAI_API_KEY만 실제 값으로 바꾸세요.
# 기본값은 src/config.py 와 동일합니다. 항목 추가 시 .env.example 과 config.py 를 함께 수정하세요.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_TOP_K=4
RELEVANCE_SCORE_THRESHOLD=1.2

DATA_DIR=data/raw
UPLOAD_DIR=data/uploads
CHROMA_DIR=vectorstore/chroma

MAX_CHAT_HISTORY_TURNS=3
CHAT_HISTORY_MAX_CHARS=400
ENABLE_QUERY_REWRITE=true
FOLLOW_UP_SEARCH_K_MULTIPLIER=2

ENABLE_HYBRID_SEARCH=true
ENABLE_RERANK=true
RERANK_FETCH_MULTIPLIER=3
RRF_K=60

ENABLE_CONTEXT_COMPRESS=true
CONTEXT_MAX_CHARS=2800

ENABLE_PARENT_CHILD=true
CHILD_CHUNK_SIZE=450
CHILD_CHUNK_OVERLAP=80
PARENT_CONTENT_MAX_CHARS=6000

ENABLE_LLM_STREAMING=true
